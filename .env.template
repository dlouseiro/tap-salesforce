# End-to-end test credentials
# Copy this to .env and fill in your values.

# --- Authentication ---
# One of: browser, client_credentials, refresh_token, password
TAP_SALESFORCE_AUTH_METHOD=browser

# Your Salesforce My Domain (e.g. mycompany.my or mycompany--uat.sandbox.my)
TAP_SALESFORCE_DOMAIN=

# External Client App consumer key
TAP_SALESFORCE_CLIENT_ID=

# Only needed for client_credentials and refresh_token auth methods:
TAP_SALESFORCE_CLIENT_SECRET=

# Only needed for browser auth (optional — ephemeral port if blank):
TAP_SALESFORCE_REDIRECT_URI=

# API type: REST, BULK, or BULK2
TAP_SALESFORCE_API_TYPE=REST
